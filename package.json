{
  "name": "grove",
  "version": "1.0.0",
  "description": "A hosted knowledge API that makes Obsidian vaults searchable and writable from any MCP client.",
  "type": "module",
  "bin": {
    "grove": "./bin/grove"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmilinovich/grove.git"
  },
  "homepage": "https://grove.md",
  "author": "John Milinovich",
  "license": "MIT",
  "keywords": [
    "obsidian",
    "mcp",
    "knowledge-base",
    "model-context-protocol",
    "search",
    "ai",
    "knowledge-management",
    "personal-knowledge"
  ],
  "scripts": {
    "proxy": "tsx src/proxy.ts",
    "keys": "tsx src/keys.ts",
    "grove": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit/",
    "test:int": "vitest run test/integration/",
    "test:smoke": "bats test/smoke/*.bats",
    "test:eval": "tsx scripts/run-evals.ts",
    "iterate": "tsx scripts/iterate.ts",
    "check:plan": "tsx scripts/check-plan-drift.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
